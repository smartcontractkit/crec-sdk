{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Credential Registry Events",
  "description": "Event schemas for the ACE CCID Credential Registry contract",
  "type": "object",
  "definitions": {
    "CredentialRegisteredEvent": {
      "type": "object",
      "properties": {
        "ccid": {
          "type": "string",
          "description": "The CCID (bytes32) of the identity"
        },
        "credentialTypeId": {
          "type": "string",
          "description": "The credential type ID (bytes32)"
        },
        "expiresAt": {
          "type": "string",
          "description": "The expiration timestamp (uint40)"
        },
        "credentialData": {
          "type": "string",
          "description": "The credential data (bytes)"
        }
      },
      "required": ["ccid", "credentialTypeId", "expiresAt", "credentialData"],
      "additionalProperties": false
    },
    "CredentialRemovedEvent": {
      "type": "object",
      "properties": {
        "ccid": {
          "type": "string",
          "description": "The CCID (bytes32) of the identity"
        },
        "credentialTypeId": {
          "type": "string",
          "description": "The credential type ID (bytes32)"
        }
      },
      "required": ["ccid", "credentialTypeId"],
      "additionalProperties": false
    },
    "CredentialRenewedEvent": {
      "type": "object",
      "properties": {
        "ccid": {
          "type": "string",
          "description": "The CCID (bytes32) of the identity"
        },
        "credentialTypeId": {
          "type": "string",
          "description": "The credential type ID (bytes32)"
        },
        "expiresAt": {
          "type": "string",
          "description": "The new expiration timestamp (uint40)"
        }
      },
      "required": ["ccid", "credentialTypeId", "expiresAt"],
      "additionalProperties": false
    },
    "InitializedEvent": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "description": "The version number of the initialization"
        }
      },
      "required": ["version"],
      "additionalProperties": false
    },
    "OwnershipTransferredEvent": {
      "type": "object",
      "properties": {
        "previousOwner": {
          "type": "string",
          "description": "The address of the previous owner"
        },
        "newOwner": {
          "type": "string",
          "description": "The address of the new owner"
        }
      },
      "required": ["previousOwner", "newOwner"],
      "additionalProperties": false
    },
    "PolicyEngineAttachedEvent": {
      "type": "object",
      "properties": {
        "policyEngine": {
          "type": "string",
          "description": "The address of the attached policy engine"
        }
      },
      "required": ["policyEngine"],
      "additionalProperties": false
    },
    "CredentialRegistryEvent": {
      "type": "object",
      "properties": {
        "event": {
          "oneOf": [
            { "$ref": "#/definitions/CredentialRegisteredEvent" },
            { "$ref": "#/definitions/CredentialRemovedEvent" },
            { "$ref": "#/definitions/CredentialRenewedEvent" },
            { "$ref": "#/definitions/InitializedEvent" },
            { "$ref": "#/definitions/OwnershipTransferredEvent" },
            { "$ref": "#/definitions/PolicyEngineAttachedEvent" }
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the event was created"
        }
      },
      "required": ["event"],
      "additionalProperties": false
    }
  },
  "properties": {
    "credentialRegistered": { "$ref": "#/definitions/CredentialRegistryEvent" },
    "credentialRemoved": { "$ref": "#/definitions/CredentialRegistryEvent" },
    "credentialRenewed": { "$ref": "#/definitions/CredentialRegistryEvent" },
    "initialized": { "$ref": "#/definitions/CredentialRegistryEvent" },
    "ownershipTransferred": { "$ref": "#/definitions/CredentialRegistryEvent" },
    "policyEngineAttached": { "$ref": "#/definitions/CredentialRegistryEvent" }
  },
  "additionalProperties": false
}
