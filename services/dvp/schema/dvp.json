{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dvp",
  "type": "object",
  "properties": {
    "SettlementOpened": {
      "$ref": "#/$defs/dvpEvent",
      "description": "Emitted when a new settlement has been opened by a seller."
    },
    "SettlementAccepted": {
      "$ref": "#/$defs/dvpEvent",
      "description": "Emitted when a a settlement has accepted by the buyer."
    },
    "SettlementClosing": {
      "$ref": "#/$defs/dvpEvent",
      "description": "Emitted when a settlement is in the final phase of closing."
    },
    "SettlementSettled": {
      "$ref": "#/$defs/dvpEvent",
      "description": "Emitted when a settlement has completed and is now settled."
    },
    "SettlementCanceling": {
      "$ref": "#/$defs/dvpEvent",
      "description": "Emitted when a settlement has requested to be canceled by one of the parties."
    },
    "SettlementCanceled": {
      "$ref": "#/$defs/dvpEvent",
      "description": "Emitted when a settlement has completely been canceled."
    }
  },
  "$defs": {
    "dvpEvent": {
      "type": "object",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the event was created"
        },
        "event": {
          "$ref": "#/$defs/evmEvent"
        },
        "parameters": {
          "$ref": "#/$defs/dvpEventParameters"
        },
        "transaction": {
          "$ref": "#/$defs/transaction"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      },
      "required": [
        "created_at",
        "event",
        "parameters",
        "transaction",
        "metadata"
      ]
    },
    "evmEvent": {
      "type": "object",
      "properties": {
        "service": {
          "type": "string",
          "description": "The service type of the event"
        },
        "name": {
          "type": "string",
          "description": "The name of the event"
        },
        "address": {
          "type": "string",
          "description": "The address of the contract that emitted the event"
        },
        "topic_hash": {
          "type": "string",
          "description": "The topic hash of the event"
        },
        "log_index": {
          "type": "integer",
          "description": "The log index of the event"
        }
      },
      "required": [
        "service",
        "name",
        "address",
        "topic_hash",
        "log_index"
      ]
    },
    "dvpEventParameters": {
      "type": "object",
      "properties": {
        "settlement_id": {
          "type": "string",
          "description": "Unique settlement ID, represented as a big integer in string format"
        },
        "settlement_hash": {
          "type": "string",
          "description": "The hash of the settlement"
        }
      },
      "required": [
        "settlement_id",
        "settlement_hash"
      ]
    },
    "transaction": {
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "integer",
          "description": "The unix timestamp of the transaction"
        },
        "chain_id": {
          "type": "string",
          "description": "The chain ID for the transaction"
        },
        "hash": {
          "type": "string",
          "description": "The hash of the transaction"
        }
      },
      "required": [
        "timestamp",
        "chain_id",
        "hash"
      ]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "dvp": {
          "$ref": "#/$defs/dvpSettlement"
        }
      }
    },
    "dvpSettlement": {
      "type": "object",
      "properties": {
        "party_info": {
          "$ref": "#/$defs/dvpSettlementPartyInfo"
        },
        "token_info": {
          "$ref": "#/$defs/dvpSettlementTokenInfo"
        },
        "delivery_info": {
          "$ref": "#/$defs/dvpSettlementDeliveryInfo"
        },
        "secret_hash": {
          "type": "string",
          "description": "32-byte hex string"
        },
        "execute_after": {
          "type": "integer",
          "description": "The unix timestamp after which the settlement can be executed"
        },
        "expiration": {
          "type": "integer",
          "description": "The unix timestamp after which the settlement expires"
        },
        "ccip_callback_gas_limit": {
          "type": "integer",
          "description": "The gas limit for the CCIP callback"
        },
        "data": {
          "type": "string",
          "description": "Attached DvP data"
        }
      },
      "required": [
        "party_info",
        "token_info",
        "delivery_info",
        "secret_hash",
        "execute_after",
        "expiration",
        "ccip_callback_gas_limit",
        "data"
      ]
    },
    "dvpSettlementPartyInfo": {
      "type": "object",
      "properties": {
        "buyer_source_address": {
          "type": "string"
        },
        "buyer_destination_address": {
          "type": "string"
        },
        "seller_source_address": {
          "type": "string"
        },
        "seller_destination_address": {
          "type": "string"
        },
        "executor_address": {
          "type": "string"
        }
      },
      "required": [
        "buyer_source_address",
        "buyer_destination_address",
        "seller_source_address",
        "seller_destination_address",
        "executor_address"
      ]
    },
    "dvpSettlementTokenInfo": {
      "type": "object",
      "properties": {
        "payment_token_source_address": {
          "type": "string"
        },
        "payment_token_destination_address": {
          "type": "string"
        },
        "asset_token_source_address": {
          "type": "string"
        },
        "asset_token_destination_address": {
          "type": "string"
        },
        "payment_currency": {
          "type": "integer"
        },
        "payment_token_amount": {
          "type": "string"
        },
        "asset_token_amount": {
          "type": "string"
        },
        "payment_token_type": {
          "type": "integer"
        },
        "asset_token_type": {
          "type": "integer"
        }
      },
      "required": [
        "payment_token_source_address",
        "payment_token_destination_address",
        "asset_token_source_address",
        "asset_token_destination_address",
        "payment_currency",
        "payment_token_amount",
        "asset_token_amount",
        "payment_token_type",
        "asset_token_type"
      ]
    },
    "dvpSettlementDeliveryInfo": {
      "type": "object",
      "properties": {
        "payment_source_chain_selector": {
          "type": "string"
        },
        "payment_destination_chain_selector": {
          "type": "string"
        },
        "asset_source_chain_selector": {
          "type": "string"
        },
        "asset_destination_chain_selector": {
          "type": "string"
        }
      },
      "required": [
        "payment_source_chain_selector",
        "payment_destination_chain_selector",
        "asset_source_chain_selector",
        "asset_destination_chain_selector"
      ]
    }
  }
}